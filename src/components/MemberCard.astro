---
import type { Member } from "@data/members";

type Props = {
  member: Member;
};

const { member } = Astro.props;
const initials = member.name
  .split(" ")
  .map((part) => part[0])
  .join("")
  .slice(0, 2)
  .toUpperCase();
const photoSrc = member.photo
  ? member.photo.startsWith("http") || member.photo.startsWith("/")
    ? member.photo
    : `${import.meta.env.BASE_URL}${member.photo}`
  : "";
---

<article class="member-card">
  {
    member.photo ? (
      <img
        class="member-photo"
        src={photoSrc}
        alt={member.photoAlt || `${member.name} portrait`}
        loading="lazy"
      />
    ) : (
      <div class="avatar" aria-hidden="true">{initials}</div>
    )
  }
  <div class="member-meta">
    <small>{member.role}</small>
    <div class="member-name-row">
      <h3>{member.name}</h3>
      {
        member.portfolioUrl && (
          <a
            class="member-portfolio-link"
            href={member.portfolioUrl}
            target="_blank"
            rel="noreferrer"
            aria-label={`${member.name} portfolio`}
          >
            Portfolio
          </a>
        )
      }
    </div>
    {member.email && <a class="member-email" href={`mailto:${member.email}`}>{member.email}</a>}
  </div>
  {member.interests && member.interests.length > 0 && (
    <ul class="theme-list" aria-label={`${member.name} research interests`}>
      {member.interests.map((interest) => <li>{interest}</li>)}
    </ul>
  )}
</article>
