---
import { lab, navItems } from "@data/site";

const base = import.meta.env.BASE_URL;
const currentPath = Astro.url.pathname.replace(base, "/").replace(/\/$/, "") || "/";
const withBase = (href: string) => `${base}${href.replace(/^\//, "")}`;
const isCurrent = (href: string) => {
  const normalized = href.replace(/\/$/, "") || "/";
  return normalized === "/"
    ? currentPath === normalized
    : currentPath === normalized || currentPath.startsWith(`${normalized}/`);
};
---

<header class="site-header">
  <div class="container nav-bar">
    <a class="brand" href={withBase("/")} aria-label={`${lab.name} home`}>
      <span class="brand-mark">IDS</span>
      <span class="brand-name">
        {lab.shortName}
        <span>{lab.affiliation}</span>
      </span>
    </a>
    <nav class="nav-links" aria-label="Primary navigation">
      {navItems.map((item) => (
        <a href={withBase(item.href)} aria-current={isCurrent(item.href) ? "page" : undefined}>
          {item.label}
        </a>
      ))}
    </nav>
  </div>
</header>
