---
import BaseLayout from "@layouts/BaseLayout.astro";
import { galleryEvents, type GalleryEvent } from "@data/gallery";

type Props = {
  event: GalleryEvent;
};

export function getStaticPaths() {
  return galleryEvents.map((event) => ({
    params: { slug: event.slug },
    props: { event },
  }));
}

const { event } = Astro.props;
const base = import.meta.env.BASE_URL;
const withBase = (href: string) => `${base}${href.replace(/^\//, "")}`;
---

<BaseLayout title={event.title} description={event.summary}>
  <section class="page-hero gallery-event-hero">
    <div class="container">
      <span class="eyebrow">Gallery</span>
      <p class="gallery-event-date">
        <time datetime={event.date}>{event.dateLabel}</time>
        {event.location && <span>{event.location}</span>}
      </p>
      <h1>{event.title}</h1>
      <p>{event.summary}</p>
    </div>
  </section>

  <section class="section">
    <div class="container">
      {
        event.images.length > 0 ? (
          <div class={event.images.length === 1 ? "photo-grid single" : "photo-grid"}>
            {event.images.map((image) => (
              <figure class="photo-item">
                <img src={withBase(image.src)} alt={image.alt} loading="lazy" />
                {image.caption && <figcaption>{image.caption}</figcaption>}
              </figure>
            ))}
          </div>
        ) : (
          <div class="empty-gallery">
            <span>{event.dateLabel}</span>
            <h2>{event.title}</h2>
            <p>Photos for this event are ready to be added.</p>
          </div>
        )
      }
    </div>
  </section>
</BaseLayout>
